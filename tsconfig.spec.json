/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJs",
    "outDir": "./out-tsc/spec",
    "rootDir": "./src",
    "types": [
      "jest",
      "node",
      "jasmine"
    ],
    "esModuleInterop": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
